# Database provider: true = SQLite, false = PostgreSQL
UseSqlite=false

# PostgreSQL (used when UseSqlite=false)
ConnectionStrings__Postgres=Host=db;Port=5432;Database=portfolio;Username=portfolio;Password=portfolio_dev

# SQLite (used when UseSqlite=true)
ConnectionStrings__Sqlite=Data Source=portfolio_dev.db

# CORS origins (comma-separated)
CorsOrigins__0=http://localhost:5173
CorsOrigins__1=http://localhost:3000

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
